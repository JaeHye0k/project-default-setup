{
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git stash list *)",
      "Bash(git tag *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(whoami *)",
      "Bash(pwd *)",
      "Bash(echo *)",
      "Bash(tree *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(type *)",
      "Bash(uname *)",
      "Bash(grep *)",
      "Bash(cd *)"
    ]
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "portone-integration@portone": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "outputStyle": "explanatory",
  "language": "Korean"
}
